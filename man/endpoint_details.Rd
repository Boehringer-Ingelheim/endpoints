\item{Binary}{
\code{Bin_1}, \code{Bin_2}, \dots
}
\item{Count}{
\code{Int_1}, \code{Int_2}, \dots
}
\item{Time-to-event}{
\code{TTE_1}, \code{TTE_2}, \dots
}
\item{TTE event indicators}{
\code{Status_1}, \code{Status_2}, \dots, where \code{1 = event} and
\code{0 = censored}
}
}
