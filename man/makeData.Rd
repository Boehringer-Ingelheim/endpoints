  endpoint_type  = "tte",
  baseline_rate  = 1 / 24,
  trt_effect     = log(0.8),
  fatal_event    = TRUE
)

sim_tte <- makeData(
  correlation_matrix    = NULL,
  sample_size_per_group = 500,
  endpoint_details      = list(ep_tte),
  enrollment_details    = list(
    administrative_censoring    = 24,
    enrollment_distribution     = "exponential",
    enrollment_exponential_rate = 1 / 4
  )
)

summary(sim_tte)

