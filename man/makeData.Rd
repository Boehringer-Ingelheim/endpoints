  endpoint_type = "continuous",
  baseline_mean = 10,
  sd            = 2,
  trt_effect    = -1
)

ep_bin <- list(
  endpoint_type = "binary",
  baseline_prob = 0.30,
  trt_prob      = 0.45
)

ep_cnt <- list(
  endpoint_type = "count",
  baseline_mean = 8,
  trt_count     = 10,
  size          = 20,
  p_zero        = 0
)

sim3 <- makeData(
  correlation_matrix    = R3,
  sample_size_per_group = 1000,
  SEED                  = 123,
  endpoint_details      = list(ep_cont, ep_bin, ep_cnt),
  target_correlation    = TRUE
)

